<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="scara_manipulator">

  <xacro:arg name="is_sim" default="true"/>
  <xacro:include filename="$(find scara_description)/urdf/scara_gazebo.xacro" />
  <xacro:include filename="$(find scara_description)/urdf/scara_ros2_control.xacro" />

  <xacro:property name="PI" value="3.14159265359" />
  <xacro:property name="limit_effort" value="30.0" />
  <xacro:property name="limit_velocity" value="10.0" />

  <material name="robot_color_1"><color rgba="0.2 0.2 0.2 1"/></material>
  <material name="robot_color_2"><color rgba="0.8 0.8 0.8 1"/></material>

  <xacro:macro name="calc_inertia" params="m">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}" />
      <inertia ixx="${m * 0.01}" ixy="0.0" ixz="0.0" iyy="${m * 0.01}" iyz="0.0" izz="${m * 0.01}"/>
    </inertial>
  </xacro:macro>

  <link name="world"/>

  <joint name="world_fixed_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0.1 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <xacro:calc_inertia m="2.1"/>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/bs.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_1"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/bs.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <link name="es_link">
    <xacro:calc_inertia m="0.55"/>
    <visual>
      <origin xyz="-0.1 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/es.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_2"/>
    </visual>
    <collision>
      <origin xyz="-0.1 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/es.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="es_link"/>
    <origin xyz="0.0 0 0.16" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="${limit_effort}" velocity="${limit_velocity}"/>
  </joint>

  <link name="as_link">
    <xacro:calc_inertia m="0.5"/>
    <visual>
      <origin xyz="-0.1 0.0 0.1" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/as.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_1"/>
    </visual>
    <collision>
      <origin xyz="-0.1 0.0 0.1" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/as.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="es_link"/>
    <child link="as_link"/>
    <origin xyz="-0.205 0 0.03" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="${limit_effort}" velocity="${limit_velocity}"/>
  </joint>

  <link name="cs_link">
    <xacro:calc_inertia m="0.15"/>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/cs.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_2"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/cs.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="joint_3" type="prismatic">
    <parent link="as_link"/>
    <child link="cs_link"/>
    <origin xyz="-0.245 0 0.15" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="-0.05" upper="0" effort="${limit_effort}" velocity="${limit_velocity}"/>
  </joint>

  <link name="g1_gripper">
    <xacro:calc_inertia m="0.1"/>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/g1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_1"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><mesh filename="package://scara_description/meshes/g1.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="wrist_joint" type="revolute">
    <parent link="cs_link"/>
    <child link="g1_gripper"/>
    <origin xyz="0 0 -0.17" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="${limit_effort}" velocity="${limit_velocity}"/>
  </joint>

  <link name="g2_gripper">
    <xacro:calc_inertia m="0.03"/>
    <visual>
      <origin xyz="-0.02 0.02 -0.03" rpy="0 ${PI / 2} -${PI / 2}"/>
      <geometry><mesh filename="package://scara_description/meshes/g2.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_2"/>
    </visual>
    <collision>
      <origin xyz="-0.02 0.02 -0.03" rpy="0 ${PI / 2} -${PI / 2}"/>
      <geometry><mesh filename="package://scara_description/meshes/g2.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="gripper_joint1" type="revolute">
    <parent link="g1_gripper"/>
    <child link="g2_gripper"/>
    <origin xyz="-0.01 0.030 -0.0225" rpy="0 -${PI / 2} 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="2.0" effort="${limit_effort}" velocity="${limit_velocity}"/>
  </joint>

  <link name="g3_gripper">
    <xacro:calc_inertia m="0.03"/>
    <visual>
      <origin xyz="-0.0 -0.02 -0.03" rpy="${PI / 2 } 0 ${PI}"/>
      <geometry><mesh filename="package://scara_description/meshes/g3.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="robot_color_2"/>
    </visual>
    <collision>
      <origin xyz="-0.02 -0.02 -0.03" rpy="${PI / 2} 0 ${PI}"/>
      <geometry><mesh filename="package://scara_description/meshes/g3.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="gripper_joint2" type="revolute">
    <parent link="g1_gripper"/>
    <child link="g3_gripper"/>
    <origin xyz="-0.01 -0.030 -0.0225" rpy="0 -${PI / 2} 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="0" effort="${limit_effort}" velocity="${limit_velocity}"/>
    <mimic joint="gripper_joint1" multiplier="-1.0" offset="0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="es_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="as_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="cs_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="g1_gripper">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="g2_gripper">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="g3_gripper">
    <material>Gazebo/White</material>
  </gazebo>

</robot>